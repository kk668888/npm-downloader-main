{
  "name": "@npm-downloader/client",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "serve:static": "serve dist -p 3001 -s",
    "test": "playwright test tests/smoke.spec.ts",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:report": "playwright show-report",
    "test:contrast": "npx tsx tests/contrast-check.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@npm-downloader/types": "workspace:*",
    "serve": "^14.2.4",
    "tslib": "^2.8.1",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.23",
    "happy-dom": "^17.4.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "unplugin-auto-import": "^0.18.3",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^6.0.11",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.0"
  }
}
