# Server Configuration

# 服务端口 (默认: 3002)
PORT=3002

# ============================================
# 目录配置
# ============================================

# 上传文件存储目录
# 用途：multer 上传的 lockfile 临时存储
# 默认：./uploads
UPLOAD_DIR=./uploads

# 临时文件目录
# 用途：下载任务、临时文件等
# 默认：./temp
TEMP_DIR=./temp

# 数据目录
# 用途：历史记录、任务日志等持久化数据
# 默认：./packages/server/data
DATA_DIR=./packages/server/data

# ============================================
# 配置说明
# ============================================
#
# 1. 复制此文件为 .env: cp .env.example .env
#
# 2. 根据需要修改配置
#
# 3. 相对路径说明:
#    - ./uploads  → 项目根目录的 uploads 文件夹
#    - uploads   → 当前工作目录的 uploads 文件夹
#    - /data/uploads → 绝对路径
#
# 4. .env 文件不会被 git 跟踪（已在 .gitignore 中）
